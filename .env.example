# Configuracion de Shopify (en Railway ya estan seteadas)
# NO commitear el archivo .env real, solo este ejemplo.

# Dominio del Shopify central
SHOPIFY_STORE_DOMAIN=kairos-brewing.myshopify.com

# Token de Admin API (secreto). Solo via env var.
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Version del Admin API (opcional, default 2024-10)
SHOPIFY_API_VERSION=2024-10

# Vendor a filtrar (opcional, default Banny)
VENDOR=Banny

# Puerto (Railway lo inyecta automaticamente)
PORT=3000
